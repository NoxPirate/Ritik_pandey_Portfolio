# ==============================================
# RUTURAJ NAWALE PORTFOLIO - ENVIRONMENT VARIABLES
# ==============================================

# Site Configuration
# -----------------
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME="Ruturaj Nawale Portfolio"

# Analytics (Optional)
# -------------------
# Google Analytics Measurement ID
# Get from: https://analytics.google.com/
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Analytics (Automatically enabled on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Contact Form Integration (Optional)
# ----------------------------------
# Resend API Key for email functionality
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# CONTACT_EMAIL=your-email@example.com

# Email Service Alternative: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Feature Flags
# ------------
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_CONTACT_FORM=true
# NEXT_PUBLIC_ENABLE_RESUME_DOWNLOAD=true

# Development Only
# ---------------
# Set to 'true' to enable debug logging
# NEXT_PUBLIC_DEBUG_MODE=false
